# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# Users configure these via the Secrets panel in the AI Studio UI.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Contact form email: optional Web3Forms (preferred). Recipient is set in the Web3Forms dashboard.
VITE_WEB3FORMS_ACCESS_KEY=
# Optional: public inbox (footer, contact page) + FormSubmit default. Overrides post@ronningenselskapslokale.no when set.
VITE_VENUE_CONTACT_EMAIL=
# Optional: FormSubmit recipient only (overrides VITE_VENUE_CONTACT_EMAIL for submissions when Web3Forms is unset).
VITE_CONTACT_NOTIFY_EMAIL=
